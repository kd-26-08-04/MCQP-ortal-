# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/mcq_test

# Required in production — use a long random string
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated allowed frontend origins
FRONTEND_URL=http://localhost:5173

# Admin bootstrap credentials (login only; registration cannot create admins)
ADMIN_USERNAME=admin@yourcompany.com
ADMIN_PASSWORD=use-a-strong-password-here

# Optional test duration override (minutes)
TEST_TIME_LIMIT_MINUTES=20
